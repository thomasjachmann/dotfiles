#!/bin/bash

set -e

data_dir="${XDG_DATA_HOME-~/.local/share}/k"
mkdir -p "$data_dir"

function cleanup() {
  echo -e "$1" |
    awk NF |               # strip whitespace (eg empty lines from multiline string creation)
    awk '{ $1=$1; print }' # to strip leading whitespace from lines (eg spaces due to the indented string creation)
}

function get_pos() {
  echo -e "$1" | awk "/^$2/{ print NR; exit }"
}

function ask() {
  local what="$1"
  local list="$2"
  shift
  shift

  # TODO: also: --layout=list-reverse
  echo -e "$list" |
    fzf \
      --highlight-line \
      --delimiter ";" \
      --bind "load:change-prompt:$what> " \
      --ghost "choose a $what" \
      --bind "change:first" \
      "$@" ||
    (echo "no $what selected" 1>&2 && exit 1)
}

function get_data() {
  local data=$(cat "$data_dir/$1" 2>/dev/null)
  [ -z "$data" ] && data="$2"
  echo "$data"
}

function set_data() {
  echo "$2" >"$data_dir/$1"
}

##################################################
## select config #################################
##################################################
configs_file="$data_dir/configs"
configs=$([ -f "$configs_file" ] && cat "$configs_file" || echo "")
previous_config=$(get_data "previous_config" "")
pos=$(get_pos "$configs" "$previous_config")
response=$(
  ask config "$configs" \
    --with-nth "{n}: {1} - {3}" \
    --accept-nth "{1};{2}" \
    --bind "load:pos($pos)" \
    --bind "one:accept"
)
config=$(echo $response | cut -d ';' -f1)
configfile=$(echo $response | cut -d ';' -f2)
set_data "previous_config" "$config"

export KUBECONFIG="${configfile/#\~/$HOME}"

##################################################
## select context ################################
##################################################
contexts=$(kubectl config get-contexts -o name)
# need to use awk in the next line to strip off leading spaces
if [ "$(echo "$contexts" | wc -l | awk '{ print $1 }')" == "1" ]; then
  context="$contexts"
else
  previous_context=$(get_data "previous_context_$config" "")
  pos=$(get_pos "$contexts" "$previous_context")
  context=$(
    ask context "$contexts" \
      --with-nth "{n}: {1}" \
      --bind "load:pos($pos)" \
      --bind "one:accept"
  )
  set_data "previous_context_$config" "$context"
fi

##################################################
## select namespace ##############################
##################################################
namespaces_file="$data_dir/namespaces"
config_namespaces=$([ -f "$namespaces_file" ] && (rg "^${config};" "$namespaces_file" | cut -d ';' -f2 -f3) || echo "")
with_nth="{1} - {2}"
if [ "$config_namespaces" == "" ]; then
  config_namespaces=$(
    kubectl get namespaces \
      --no-headers \
      -o custom-columns=NAME:.metadata.name \
      --context "$context"
  )
  with_nth="{1}"
fi

# need to use awk in the next line to strip off leading spaces
if [ "$(echo "$config_namespaces" | wc -l | awk '{ print $1 }')" == "1" ]; then
  namespace=$(echo $config_namespaces | cut -d ';' -f1)
else
  previous_namespace=$(get_data "previous_namespace_${config}_${context}" "")
  pos=$(get_pos "$config_namespaces" "$previous_namespace")
  namespace=$(
    ask namespace "$config_namespaces" \
      --with-nth "{n}: $with_nth" \
      --accept-nth 1 \
      --bind "load:pos($pos)" \
      --bind "one:accept"
  )
  set_data "previous_namespace_${config}_${context}" "$namespace"
fi

##################################################
## select command ################################
##################################################
commands=$(cleanup "
  k9s;cluster client;k9s_subcommand
  shell;kubectl -> bash;pod_container
  console;kubectl -> rails console;pod_container
  upload;kubectl (upload a local file);pod_container
  download;kubectl (download a remote file);pod_container
")
previous_command=$(get_data "previous_command_${config}_${context}_${namespace}" "")
pos=$(get_pos "$commands" "$previous_command")
response=$(
  ask command "$commands" \
    --with-nth "{n}: {1} - {2}" \
    --accept-nth "{1};{3}" \
    --bind "load:pos($pos)" \
    --bind "one:accept"
)
command=$(echo $response | cut -d ';' -f1)
preparation=$(echo $response | cut -d ';' -f2)
set_data "previous_command_${config}_${context}_${namespace}" "$command"

##################################################
## optional preparation ##########################
##################################################
case $preparation in
k9s_subcommand)
  ##################################################
  ## select k9s subcommand #########################
  ##################################################
  k9s_subcommands=$(cleanup "
    configmaps
    deployments
    ingresses
    pods
    secrets
    services
  ")
  previous_k9s_subcommand=$(get_data "previous_k9s_subcommand_${config}_${context}_${namespace}" "")
  pos=$(get_pos "$k9s_subcommands" "$previous_k9s_subcommand")
  k9s_subcommand=$(
    ask k9s_subcommand "$k9s_subcommands" \
      --with-nth "{n}: {1}" \
      --accept-nth "{1}" \
      --bind "load:pos($pos)" \
      --bind "one:accept"
  )
  set_data "previous_k9s_subcommand_${config}_${context}_${namespace}" "$k9s_subcommand"
  ;;

pod_container)
  ##################################################
  ## select pod ####################################
  ##################################################
  pods=$(
    kubectl get pods \
      --no-headers \
      -o custom-columns=NAME:.metadata.name \
      --context "$context" \
      --namespace "$namespace"
  )

  # need to use awk in the next line to strip off leading spaces
  if [ "$(echo "$pods" | wc -l | awk '{ print $1 }')" == "1" ]; then
    pod="$pods"
  else
    previous_pod=$(get_data "previous_pod_${config}_${context}_${namespace}" "")
    pos=$(get_pos "$pods" "$previous_pod")
    pod=$(
      ask pod "$pods" \
        --with-nth "{n}: {1}" \
        --accept-nth 1 \
        --bind "load:pos($pos)" \
        --bind "one:accept"
    )
    set_data "previous_pod_${config}_${context}_${namespace}" "$pod"
  fi

  ##################################################
  ## select container within pod ###################
  ##################################################
  containers=$(
    kubectl get pods \
      --no-headers \
      -o jsonpath='{.spec.containers[*].name}' \
      --context "$context" \
      --namespace "$namespace" \
      "$pod" |
      tr -s '[[:space:]]' '\n'
  )

  # need to use awk in the next line to strip off leading spaces
  if [ "$(echo "$containers" | wc -l | awk '{ print $1 }')" == "1" ]; then
    container="$containers"
  else
    previous_container=$(get_data "previous_container_${config}_${context}_${namespace}" "")
    pos=$(get_pos "$containers" "$previous_container")
    container=$(
      ask container "$containers" \
        --with-nth "{n}: {1}" \
        --accept-nth 1 \
        --bind "load:pos($pos)" \
        --bind "one:accept"
    )
    set_data "previous_container_${config}_${context}_${namespace}" "$container"
  fi
  ;;
esac

# FYI: `--kubeconfig "$KUBECONFIG"` is added for commands after `set -x` so that this output can
# be copy/pasted to repeat that command although it is not necessary to the `KUBECONFIG` variable
case $command in
k9s)
  set -x
  k9s --kubeconfig "$KUBECONFIG" --context "$context" --namespace "$namespace" --command "$k9s_subcommand"
  ;;

shell)
  set -x
  kubectl --kubeconfig "$KUBECONFIG" exec -it --context "$context" --namespace "$namespace" "$pod" --container "$container" -- /bin/bash
  ;;

console)
  set -x
  kubectl --kubeconfig "$KUBECONFIG" exec -it --context "$context" --namespace "$namespace" "$pod" --container "$container" -- bin/rails c
  ;;

upload)
  path=$(ask file "$(fd .)")
  file=$(basename "$path")

  set -x
  kubectl --kubeconfig "$KUBECONFIG" cp --context "$context" --namespace=$namespace --container=$container --no-preserve "$file" "$namespace/$pod:$file"
  ;;

download)
  files=$(kubectl exec -it --context "$context" --namespace "$namespace" "$pod" --container "$container" -- find . -printf '%P\n' | tr -d '\r')
  path=$(ask file "$files")
  file=$(basename "$path")

  set -x
  kubectl cp --kubeconfig "$KUBECONFIG" --context "$context" --namespace=$namespace --container=$container --no-preserve "$namespace/$pod:$path" "$file"
  ;;

*)
  echo "unknown command" 1>&2
  exit 1
  ;;
esac
